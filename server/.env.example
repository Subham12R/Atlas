# Copy to .env and paste your API keys. SENSITIVE -- .env is gitignored.
# Keys saved later via the desktop app's Profile -> Advanced settings are
# stored in CREDENTIALS_DB_PATH instead and take precedence over these.

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# Local LLM (Ollama or any other OpenAI-compatible local server). No API key
# needed by default.
LOCAL_LLM_BASE_URL=http://localhost:11434/v1
LOCAL_LLM_MODEL=llama3.2

# Web search / research mode (Tavily -- tavily.com)
TAVILY_API_KEY=

# Voice typing (Groq Whisper -- console.groq.com)
GROQ_API_KEY=

# Runtime overrides written by the Advanced settings UI live here instead of
# being rewritten into .env -- .env only seeds the very first value.
CREDENTIALS_DB_PATH=credentials.db

# ---- Brain (persistent memory core) --------------------------------------
# All optional; sensible defaults shown. See ARCHITECTURE.md.
BRAIN_ENABLED=1                          # 0 = plain adapters, no memory
BRAIN_DB_PATH=brain.db                   # SQLite file (gitignore it)
BRAIN_EMBED_MODEL=BAAI/bge-small-en-v1.5 # fastembed model (384-dim)
BRAIN_EMBED_DIM=384
BRAIN_SUMMARIZER=openai                  # provider used to write summaries + extract graph
BRAIN_AUTO_SUMMARY=1                     # 0 = RAG only (no LLM summary/graph, no extra quota)
BRAIN_TOPK=6                             # semantic hits injected per turn (also the pool floor for dynamic recall)
BRAIN_MAX_DISTANCE=0.6                   # cosine-distance cutoff (0=identical,2=opposite); blank disables, falls back to fixed top-k
BRAIN_CONTEXT_BUDGET=2000                # max chars of recalled context per turn
BRAIN_CHUNK_CHARS=800                    # hard cap: chunks larger than this are re-windowed; also the short-text bypass threshold
BRAIN_CHUNK_OVERLAP=100                  # chars of overlap when a chunk still needs hard-cap re-splitting
BRAIN_CHUNK_BREAKPOINT_TYPE=percentile   # SemanticChunker breakpoint method: percentile|standard_deviation|interquartile|gradient
BRAIN_CHUNK_BREAKPOINT_AMOUNT=           # blank = library default for the chosen type (95.0 for percentile)
